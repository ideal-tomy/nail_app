VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ログイン許可メール（カンマ区切り）。未設定時はコード内のデフォルト2件を使用
VITE_ALLOWED_EMAILS=nailluv.0212@icloud.com,ryojitomii@gmail.com

# 前日リマインド文面に含める Google マップ URL（任意）
# VITE_SALON_MAPS_URL=https://maps.app.goo.gl/xxxx

# seed:storage / LINE API 用（サーバー側のみ。VITE_ を付けない）
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# LINE Messaging API（Vercel 環境変数にも同名で設定）
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# テスト送信を自分だけに制限する場合（推奨）
LINE_TEST_USER_ID=Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
